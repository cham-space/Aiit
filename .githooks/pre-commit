#!/bin/bash
# ============================================================
# AI Development Base — pre-commit hook
# .githooks/pre-commit
#
# Runs on `git commit`.  Operates on staged files only.
# Check chain:
#   1. FORMAT      — prettier (js/ts/jsx/tsx) / ruff format (python)
#   2. LINT        — eslint (js/ts) / ruff check (python)
#   3. TYPE_CHECK  — tsc --noEmit (ts/tsx) / mypy (python)
#   4. SECRET_SCAN — gitleaks detect
#   5. TDD_GATE    — Phase A: test files must exist for staged source
#                    Phase B: run tests, detect RED/GREEN phase
#
# Each check is gated by hook_enabled "CHECK_NAME".
# Tracks errors via HAS_ERROR; exits 1 if any check fails.
# ============================================================
set -euo pipefail

# Resolve the directory containing *this* script, then source utils.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/utils.sh"

# We want to continue through all checks even if one fails, so temporarily
# relax -e for the body of the hook.  We restore it at the end.
set +e

HAS_ERROR=0
ROOT_DIR="$(git rev-parse --show-toplevel)"

echo ""
echo "=============================================="
echo "  AI Development Base — pre-commit checks"
echo "=============================================="
echo ""

# --- AIIT SCRIPTS ---
AIIT_SCRIPTS=".claude/scripts"

# --------------------------------------------------------------------
# 1. FORMAT
# --------------------------------------------------------------------
if hook_enabled "FORMAT"; then
  echo "--- [1/6] FORMAT ----------------------------------------"

  STAGED_JS_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|jsx|tsx)$' || true)
  STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

  # prettier for JavaScript / TypeScript
  if [[ -n "$STAGED_JS_TS" ]]; then
    if command -v prettier &>/dev/null; then
      echo "  Running prettier on staged JS/TS files..."
      # Write formatted output back to the staged files (we only check
      # that formatting is correct; actual rewrite happens via
      # prettier --write but we re-add below if anything changed).
      prettier --write $STAGED_JS_TS >/dev/null 2>&1
      # Re-add any files prettier changed so they are included in the commit
      for f in $STAGED_JS_TS; do
        git add "$f" 2>/dev/null || true
      done
      pass_msg "FORMAT (prettier) passed"
    else
      warn_msg "prettier not found — skipping JS/TS formatting"
    fi
  fi

  # ruff format for Python
  if [[ -n "$STAGED_PY" ]]; then
    if command -v ruff &>/dev/null; then
      echo "  Running ruff format on staged Python files..."
      ruff format $STAGED_PY 2>&1 || {
        fail_msg "FORMAT (ruff format) failed"
        HAS_ERROR=1
      }
      # Re-add any files ruff changed
      for f in $STAGED_PY; do
        git add "$f" 2>/dev/null || true
      done
      if [[ $HAS_ERROR -eq 0 ]]; then
        pass_msg "FORMAT (ruff format) passed"
      fi
    else
      warn_msg "ruff not found — skipping Python formatting"
    fi
  fi

  if [[ -z "$STAGED_JS_TS" && -z "$STAGED_PY" ]]; then
    pass_msg "FORMAT — no relevant staged files to format"
  fi
fi

# --------------------------------------------------------------------
# 2. LINT
# --------------------------------------------------------------------
if hook_enabled "LINT"; then
  echo ""
  echo "--- [2/6] LINT ------------------------------------------"

  STAGED_JS_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|jsx|tsx)$' || true)
  STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

  # eslint for JavaScript / TypeScript
  if [[ -n "$STAGED_JS_TS" ]]; then
    if command -v eslint &>/dev/null; then
      echo "  Running eslint on staged JS/TS files..."
      eslint $STAGED_JS_TS 2>&1 || {
        fail_msg "LINT (eslint) found issues"
        HAS_ERROR=1
      }
      if [[ $HAS_ERROR -eq 0 ]]; then
        pass_msg "LINT (eslint) passed"
      fi
    else
      warn_msg "eslint not found — skipping JS/TS lint"
    fi
  fi

  # ruff check for Python
  if [[ -n "$STAGED_PY" ]]; then
    if command -v ruff &>/dev/null; then
      echo "  Running ruff check on staged Python files..."
      ruff check $STAGED_PY 2>&1 || {
        fail_msg "LINT (ruff check) found issues"
        HAS_ERROR=1
      }
      if [[ $HAS_ERROR -eq 0 ]]; then
        pass_msg "LINT (ruff check) passed"
      fi
    else
      warn_msg "ruff not found — skipping Python lint"
    fi
  fi

  if [[ -z "$STAGED_JS_TS" && -z "$STAGED_PY" ]]; then
    pass_msg "LINT — no relevant staged files to lint"
  fi
fi

# --------------------------------------------------------------------
# 3. TYPE_CHECK
# --------------------------------------------------------------------
if hook_enabled "TYPE_CHECK"; then
  echo ""
  echo "--- [3/6] TYPE_CHECK ------------------------------------"

  STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)
  STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

  # tsc --noEmit for TypeScript
  if [[ -n "$STAGED_TS" ]]; then
    if command -v tsc &>/dev/null && [[ -f "tsconfig.json" ]]; then
      echo "  Running tsc --noEmit..."
      tsc --noEmit 2>&1 || {
        fail_msg "TYPE_CHECK (tsc) found type errors"
        HAS_ERROR=1
      }
      if [[ $HAS_ERROR -eq 0 ]]; then
        pass_msg "TYPE_CHECK (tsc) passed"
      fi
    else
      warn_msg "tsc / tsconfig.json not found — skipping TypeScript type check"
    fi
  fi

  # mypy for Python
  if [[ -n "$STAGED_PY" ]]; then
    if command -v mypy &>/dev/null; then
      echo "  Running mypy on staged Python files..."
      mypy $STAGED_PY 2>&1 || {
        fail_msg "TYPE_CHECK (mypy) found type errors"
        HAS_ERROR=1
      }
      if [[ $HAS_ERROR -eq 0 ]]; then
        pass_msg "TYPE_CHECK (mypy) passed"
      fi
    else
      warn_msg "mypy not found — skipping Python type check"
    fi
  fi

  if [[ -z "$STAGED_TS" && -z "$STAGED_PY" ]]; then
    pass_msg "TYPE_CHECK — no relevant staged files for type checking"
  fi
fi

# --------------------------------------------------------------------
# 4. SECRET_SCAN
# --------------------------------------------------------------------
if hook_enabled "SECRET_SCAN"; then
  echo ""
  echo "--- [4/6] SECRET_SCAN -----------------------------------"

  if command -v gitleaks &>/dev/null; then
    echo "  Running gitleaks detect..."
    gitleaks detect --verbose 2>&1 || {
      fail_msg "SECRET_SCAN (gitleaks) found potential secrets"
      HAS_ERROR=1
    }
    if [[ $HAS_ERROR -eq 0 ]]; then
      pass_msg "SECRET_SCAN (gitleaks) passed"
    fi
  else
    warn_msg "gitleaks not found — skipping secret scan"
  fi
fi

# --------------------------------------------------------------------
# 5. TDD_GATE
# --------------------------------------------------------------------
# Two-phase check:
#   Phase A — File existence: staged source files must have staged test files
#   Phase B — Test execution: run tests to verify health and detect RED phase
# --------------------------------------------------------------------
if hook_enabled "TDD_GATE"; then
  echo ""
  echo "--- [5/6] TDD_GATE --------------------------------------"

  # Collect staged source files (not test files themselves).
  STAGED_SRC=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -v '/test/' \
    | grep -v '/tests/' \
    | grep -v '/spec/' \
    | grep -v '/__tests__/' \
    | grep -v '\.test\.' \
    | grep -v '\.spec\.' \
    | grep -v '\.md$' \
    | grep -v '\.txt$' \
    | grep -v '\.json$' \
    | grep -v '\.yml$' \
    | grep -v '\.yaml$' \
    | grep -v '\.xml$' \
    | grep -v '\.template$' \
    | grep -v '\.gitkeep$' \
    | grep -v '\.gitignore$' \
    | grep -v '^\.githooks/' \
    | grep -v '^\.github/' \
    | grep -v '^\.claude/' \
    | grep -v '^bin/' \
    | grep -v '^package\.json$' \
    || true)

  # Collect staged test files.
  STAGED_TESTS=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '/test/|/tests/|/spec/|/__tests__/|\.test\.|\.spec\.|Test\.java$|_test\.go$|_test\.py$' \
    || true)

  # Collect ALL staged files (for matching purposes).
  ALL_STAGED=$(git diff --cached --name-only --diff-filter=ACM || true)

  # ===== Phase A: File Existence Check =====
  MISSING_TESTS=""

  for src_file in $STAGED_SRC; do
    # Derive expected test file names
    dir_name=$(dirname "$src_file")
    base_name=$(basename "$src_file")
    name_no_ext="${base_name%.*}"
    ext="${base_name##*.}"

    # Check common test file naming conventions
    found=0
    for test_pattern in \
      "${dir_name}/test_${base_name}" \
      "${dir_name}/${name_no_ext}.test.${ext}" \
      "${dir_name}/${name_no_ext}.spec.${ext}" \
      "${dir_name}/__tests__/${base_name}" \
      "${dir_name}/${name_no_ext}Test.${ext}" \
      "tests/${src_file}" \
      "src/test/java/${src_file#src/main/java/}" \
      "src/test/$(echo "$src_file" | sed 's|src/main/||')"
    do
      if echo "$ALL_STAGED" | grep -qF "$test_pattern"; then
        found=1
        break
      fi
    done

    # Fallback: check if ANY test file with a similar name exists in staged
    if [[ $found -eq 0 && -n "$STAGED_TESTS" ]]; then
      if echo "$STAGED_TESTS" | grep -qi "$(echo "$name_no_ext" | sed 's/[-_]/.*/g')"; then
        found=1
      fi
    fi

    if [[ $found -eq 0 ]]; then
      MISSING_TESTS="${MISSING_TESTS}  ${src_file}\n"
    fi
  done

  if [[ -n "$MISSING_TESTS" ]]; then
    fail_msg "TDD_GATE: source files staged without test files:"
    echo -e "$MISSING_TESTS"
    echo "  Please stage corresponding test files or add HOOK_TDD_GATE=0 in .githooks/config."
    HAS_ERROR=1
  else
    if [[ -z "$STAGED_SRC" && -z "$STAGED_TESTS" ]]; then
      pass_msg "TDD_GATE — no source files to check"
    else
      # ===== Phase B: Test Execution & RED Phase Detection =====

      # Detect RED phase: new test files staged WITHOUT source file changes
      if [[ -n "$STAGED_TESTS" && -z "$STAGED_SRC" ]]; then
        NEW_TEST_COUNT=$(echo "$STAGED_TESTS" | wc -l | tr -d ' ')
        echo "  [RED] Detected test-only commit (${NEW_TEST_COUNT} test file(s))"
        echo "    This appears to be a RED phase commit — writing tests before implementation."
        echo "    Tests are expected to FAIL at this stage."
        echo ""

        # Run tests — failure is expected and acceptable in RED phase
        echo "  Running tests to capture RED evidence..."
        TDD_TEST_OUTPUT=""
        TDD_TEST_EXIT=0
        TDD_TEST_CMD=""

        ecosystem=$(detect_ecosystem 2>/dev/null || echo "")
        case "$ecosystem" in
          node|npm)
            if [[ -f "package.json" ]] && grep -q '"test"' package.json 2>/dev/null; then
              TDD_TEST_CMD="npm test"
            fi
            ;;
          maven)
            [[ -f "pom.xml" ]] && TDD_TEST_CMD="mvn test -q"
            ;;
          python)
            TDD_TEST_CMD="pytest -q --tb=short"
            ;;
          go)
            [[ -f "go.mod" ]] && TDD_TEST_CMD="go test ./..."
            ;;
          rust)
            [[ -f "Cargo.toml" ]] && TDD_TEST_CMD="cargo test 2>&1"
            ;;
        esac

        if [[ -n "$TDD_TEST_CMD" ]]; then
          TDD_TEST_OUTPUT=$(timeout 120 bash -c "$TDD_TEST_CMD" 2>&1) || TDD_TEST_EXIT=$?
          if [[ $TDD_TEST_EXIT -ne 0 ]]; then
            echo "    RED evidence captured: tests failed (exit code: ${TDD_TEST_EXIT})"
            echo "    Next step: implement code to make tests pass (GREEN phase)"
            pass_msg "TDD_GATE — RED phase confirmed (tests fail as expected)"
          else
            warn_msg "TDD_GATE — tests passed in test-only commit"
            echo "    Tests should FAIL before implementation (RED phase)."
            echo "    Review test assertions — they may be too weak."
          fi
        else
          echo "    No test runner detected — RED evidence must be captured manually"
          pass_msg "TDD_GATE — test-only commit accepted (no runner to verify RED)"
        fi

      # Source + test files both staged: run tests to verify GREEN phase
      elif [[ -n "$STAGED_SRC" && -n "$STAGED_TESTS" ]]; then
        echo "  [GREEN] Source + test files staged together — verifying test health..."

        TDD_TEST_OUTPUT=""
        TDD_TEST_EXIT=0
        TDD_TEST_CMD=""

        ecosystem=$(detect_ecosystem 2>/dev/null || echo "")
        case "$ecosystem" in
          node|npm)
            if [[ -f "package.json" ]] && grep -q '"test"' package.json 2>/dev/null; then
              TDD_TEST_CMD="npm test"
            fi
            ;;
          maven)
            [[ -f "pom.xml" ]] && TDD_TEST_CMD="mvn test -q"
            ;;
          python)
            TDD_TEST_CMD="pytest -q --tb=short"
            ;;
          go)
            [[ -f "go.mod" ]] && TDD_TEST_CMD="go test ./..."
            ;;
          rust)
            [[ -f "Cargo.toml" ]] && TDD_TEST_CMD="cargo test 2>&1"
            ;;
        esac

        if [[ -n "$TDD_TEST_CMD" ]]; then
          echo "    Running: $TDD_TEST_CMD (timeout: 120s)"
          TDD_TEST_OUTPUT=$(timeout 120 bash -c "$TDD_TEST_CMD" 2>&1) || TDD_TEST_EXIT=$?

          if [[ $TDD_TEST_EXIT -ne 0 ]]; then
            fail_msg "TDD_GATE — tests FAILED:"
            echo "    Tests must pass before committing (GREEN phase)."
            echo "$TDD_TEST_OUTPUT" | tail -8 | sed 's/^/    /'
            echo ""
            echo "    Fix failing tests or implementation, then retry."
            HAS_ERROR=1
          else
            pass_msg "TDD_GATE — all tests passed (GREEN phase verified)"
          fi
        else
          pass_msg "TDD_GATE — file check passed (no test runner to verify GREEN)"
        fi

      # Source files only (no tests) — already blocked by Phase A above
      else
        pass_msg "TDD_GATE passed — all staged source files have test coverage"
      fi
    fi
  fi
fi

# --------------------------------------------------------------------
# 6. YAML_VALIDATE
# --------------------------------------------------------------------
if hook_enabled "YAML_VALIDATE"; then
  echo ""
  echo "--- [6/6] YAML_VALIDATE ---------------------------------"

  if [[ -f "${AIIT_SCRIPTS}/aiit-yaml-validate.sh" ]]; then
    YAML_FILES=$(find specs -name ".aiit.yaml" 2>/dev/null || true)
    if [[ -n "$YAML_FILES" ]]; then
      echo "  Validating .aiit.yaml state files..."
      if bash "${AIIT_SCRIPTS}/aiit-yaml-validate.sh" 2>&1; then
        pass_msg "YAML_VALIDATE passed"
      else
        fail_msg "YAML_VALIDATE — state file validation failed"
        HAS_ERROR=1
      fi
    else
      pass_msg "YAML_VALIDATE — no .aiit.yaml files to validate"
    fi
  else
    pass_msg "YAML_VALIDATE — aiit-yaml-validate.sh not found (skipped)"
  fi
fi

# --------------------------------------------------------------------
# Final summary
# --------------------------------------------------------------------
echo ""
echo "=============================================="
if [[ $HAS_ERROR -eq 0 ]]; then
  pass_msg "All pre-commit checks passed!"
  echo "=============================================="
  echo ""
  exit 0
else
  fail_msg "One or more pre-commit checks FAILED.  Please fix the issues above and try again."
  echo "=============================================="
  echo ""
  exit 1
fi
